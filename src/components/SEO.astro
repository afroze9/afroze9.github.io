---
interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
}

const { title, description, canonicalURL } = Astro.props;
const siteTitle = "Afroze Amjad | Senior Software Architect";
const fullTitle = title === "Home" ? siteTitle : `${title} | Afroze Amjad`;
const canonical = canonicalURL || Astro.url.href;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Afroze Amjad",
  url: "https://afrozeamjad.com",
  jobTitle: "Senior Software Architect",
  sameAs: [
    "https://github.com/afroze9",
    "https://linkedin.com/in/afroze-amjad"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Afroze Amjad",
  url: "https://afrozeamjad.com",
  author: { "@type": "Person", name: "Afroze Amjad" }
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="author" content="Afroze Amjad" />

<title>{fullTitle}</title>
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Afroze Amjad" />

<!-- Twitter -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />

<link id="favicon" rel="icon" type="image/svg+xml" href="/favicon.svg" />

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
