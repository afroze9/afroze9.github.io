---
interface Props {
  title: string;
  date: string;
  category: string;
  problem: string;
  solution: string;
  role: string;
  impact: string;
  technologies?: string[];
  image?: string;
  featured?: boolean;
}

const { title, date, category, problem, solution, role, impact, technologies, image, featured } = Astro.props;

const categoryLabels: Record<string, string> = {
  ai: "AI / ML",
  architecture: "Architecture",
  platform: "Platform",
  devops: "DevOps",
  integration: "Integration"
};

const categoryColors: Record<string, string> = {
  ai: "var(--color-cat-ai)",
  architecture: "var(--color-cat-arch)",
  platform: "var(--color-cat-platform)",
  devops: "var(--color-cat-devops)",
  integration: "var(--color-cat-integration)"
};
---

<article class:list={["project-card", { featured }]}>
  <div class="card-accent" style={`--accent: ${categoryColors[category]}`}></div>
  <div class="card-content">
    <header class="card-header">
      <div class="header-top">
        <span class="category" style={`--cat-color: ${categoryColors[category]}`}>
          {categoryLabels[category]}
        </span>
        <span class="date">{date}</span>
      </div>
      <h3>{title}</h3>
      <p class="role">{role}</p>
    </header>

    {image && (
      <div class="card-image">
        <img src={image} alt={`${title} screenshot`} loading="lazy" />
      </div>
    )}

    <div class="card-body">
      <div class="section">
        <span class="label">Challenge</span>
        <p>{problem}</p>
      </div>
      <div class="section">
        <span class="label">Solution</span>
        <p>{solution}</p>
      </div>
    </div>

    <footer class="card-footer">
      <div class="impact">
        <span class="impact-label">Impact</span>
        <span class="impact-value">{impact}</span>
      </div>
      {technologies && technologies.length > 0 && (
        <div class="tech-stack">
          {technologies.map((tech) => (
            <span class="tech-tag">{tech}</span>
          ))}
        </div>
      )}
    </footer>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    background: var(--color-background);
    border: var(--border-width) solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--color-accent);
  }

  .project-card.featured {
    border-width: 2px;
  }

  .card-accent {
    width: 4px;
    background: var(--accent, var(--color-accent));
    flex-shrink: 0;
  }

  .card-content {
    flex: 1;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .category {
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cat-color, var(--color-accent));
    background: var(--color-accent-light);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .date {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .card-header h3 {
    font-size: var(--font-size-lg);
    margin: var(--space-xs) 0 0 0;
    line-height: 1.3;
  }

  .role {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .card-image {
    border-radius: 4px;
    overflow: hidden;
    border: var(--border-width) solid var(--color-border);
  }

  .card-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex: 1;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .label {
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .section p {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: 1.5;
    color: var(--color-text);
  }

  .card-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: var(--space-md);
    border-top: var(--border-width) solid var(--color-border);
  }

  .impact {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .impact-label {
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .impact-value {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tech-tag {
    font-size: 0.7rem;
    padding: 2px 8px;
    background: var(--color-accent-light);
    border-radius: 4px;
    color: var(--color-text);
  }

  @media (min-width: 640px) {
    .card-footer {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .tech-stack {
      justify-content: flex-end;
      max-width: 60%;
    }
  }
</style>
