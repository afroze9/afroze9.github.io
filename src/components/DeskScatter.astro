---
// Faint software / computer glyphs scattered on the "desk" behind the paper sheet.
// Each item is absolutely positioned within the full document height.

const items = [
  // Left side — mix of clear-margin and sheet-edge positions
  { cls: "browser",   x: "4%",   y: "3%",  r: 0 },
  { cls: "hex",       x: "10%",  y: "6%",  r: 0 },
  { cls: "csharp",    x: "2%",   y: "9%",  r: 0 },
  { cls: "comment",   x: "12%",  y: "12%", r: 0 },
  { cls: "tree",      x: "4%",   y: "15%", r: 0 },
  { cls: "azure",     x: "13%",  y: "18%", r: 0 },
  { cls: "path",      x: "2%",   y: "21%", r: 0 },
  { cls: "js",        x: "11%",  y: "24%", r: 0 },
  { cls: "http",      x: "5%",   y: "27%", r: 0 },
  { cls: "cloud",     x: "12%",  y: "30%", r: 0 },
  { cls: "regex",     x: "3%",   y: "34%", r: 0 },
  { cls: "commit",    x: "13%",  y: "37%", r: 0 },
  { cls: "rust",      x: "5%",   y: "40%", r: 0 },
  { cls: "prompt",    x: "11%",  y: "43%", r: 0 },
  { cls: "spread",    x: "3%",   y: "46%", r: 0 },
  { cls: "null",      x: "12%",  y: "49%", r: 0 },
  { cls: "key",       x: "5%",   y: "52%", r: 0 },
  { cls: "docker",    x: "10%",  y: "56%", r: 0 },
  { cls: "braces",    x: "3%",   y: "60%", r: 0 },
  { cls: "ts",        x: "13%",  y: "64%", r: 0 },
  { cls: "path",      x: "4%",   y: "67%", r: 0 },
  { cls: "aws",       x: "11%",  y: "70%", r: 0 },
  { cls: "commit",    x: "2%",   y: "73%", r: 0 },
  { cls: "tree",      x: "12%",  y: "76%", r: 0 },
  { cls: "fatarrow",  x: "4%",   y: "79%", r: 0 },
  { cls: "git",       x: "11%",  y: "82%", r: 0 },
  { cls: "angle",     x: "3%",   y: "85%", r: 0 },
  { cls: "k8s",       x: "13%",  y: "88%", r: 0 },
  { cls: "regex",     x: "4%",   y: "91%", r: 0 },
  { cls: "floppy",    x: "12%",  y: "94%", r: 0 },
  { cls: "http",      x: "2%",   y: "97%", r: 0 },

  // Right side
  { cls: "path",      x: "87%",  y: "3%",  r: 0 },
  { cls: "aws",       x: "96%",  y: "6%",  r: 0 },
  { cls: "braces",    x: "88%",  y: "9%",  r: 0 },
  { cls: "cloud",     x: "95%",  y: "12%", r: 0 },
  { cls: "tree",      x: "87%",  y: "15%", r: 0 },
  { cls: "js",        x: "96%",  y: "18%", r: 0 },
  { cls: "hex",       x: "89%",  y: "21%", r: 0 },
  { cls: "azure",     x: "96%",  y: "24%", r: 0 },
  { cls: "comment",   x: "88%",  y: "27%", r: 0 },
  { cls: "browser",   x: "95%",  y: "30%", r: 0 },
  { cls: "key",       x: "88%",  y: "34%", r: 0 },
  { cls: "csharp",    x: "96%",  y: "37%", r: 0 },
  { cls: "regex",     x: "89%",  y: "40%", r: 0 },
  { cls: "prompt",    x: "96%",  y: "43%", r: 0 },
  { cls: "spread",    x: "87%",  y: "46%", r: 0 },
  { cls: "rust",      x: "95%",  y: "49%", r: 0 },
  { cls: "http",      x: "88%",  y: "52%", r: 0 },
  { cls: "ts",        x: "96%",  y: "55%", r: 0 },
  { cls: "pipe",      x: "89%",  y: "58%", r: 0 },
  { cls: "k8s",       x: "96%",  y: "61%", r: 0 },
  { cls: "binary",    x: "88%",  y: "64%", r: 0 },
  { cls: "git",       x: "95%",  y: "67%", r: 0 },
  { cls: "commit",    x: "89%",  y: "70%", r: 0 },
  { cls: "docker",    x: "96%",  y: "73%", r: 0 },
  { cls: "path",      x: "88%",  y: "76%", r: 0 },
  { cls: "cloud",     x: "96%",  y: "79%", r: 0 },
  { cls: "fatarrow",  x: "87%",  y: "82%", r: 0 },
  { cls: "js",        x: "95%",  y: "85%", r: 0 },
  { cls: "angle",     x: "88%",  y: "88%", r: 0 },
  { cls: "prompt",    x: "96%",  y: "91%", r: 0 },
  { cls: "null",      x: "89%",  y: "94%", r: 0 },
  { cls: "hex",       x: "96%",  y: "97%", r: 0 },
];
---

<div class="desk-scatter" aria-hidden="true">
  {items.map((item) => (
    <div class="ds-item" style={`left: ${item.x}; top: ${item.y}; transform: translate(-50%, -50%) rotate(${item.r}deg);`}>
      {item.cls === "braces" && (
        <svg viewBox="0 0 50 24" width="50" height="24">
          <text x="0" y="18" font-family="IBM Plex Mono, monospace" font-size="16" fill="currentColor">{'{ }'}</text>
        </svg>
      )}
      {item.cls === "fatarrow" && (
        <svg viewBox="0 0 70 20" width="70" height="20">
          <text x="0" y="14" font-family="IBM Plex Mono, monospace" font-size="12" fill="currentColor">() =&gt;</text>
        </svg>
      )}
      {item.cls === "comment" && (
        <svg viewBox="0 0 90 20" width="90" height="20">
          <text x="0" y="14" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">// TODO</text>
        </svg>
      )}
      {item.cls === "tree" && (
        <svg viewBox="0 0 80 40" width="80" height="40">
          <text x="0" y="12" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">├── src</text>
          <text x="0" y="24" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">├── lib</text>
          <text x="0" y="36" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">└── bin</text>
        </svg>
      )}
      {item.cls === "version" && (
        <svg viewBox="0 0 60 18" width="60" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">v2.4.1</text>
        </svg>
      )}
      {item.cls === "path" && (
        <svg viewBox="0 0 100 18" width="100" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">/src/api.ts</text>
        </svg>
      )}
      {item.cls === "http" && (
        <svg viewBox="0 0 60 18" width="60" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">200 OK</text>
        </svg>
      )}
      {item.cls === "diff" && (
        <svg viewBox="0 0 80 40" width="80" height="40">
          <text x="0" y="12" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">+ added</text>
          <text x="0" y="24" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">- gone</text>
          <text x="0" y="36" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">@ 42,8</text>
        </svg>
      )}
      {item.cls === "regex" && (
        <svg viewBox="0 0 80 18" width="80" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">/\w+/g</text>
        </svg>
      )}
      {item.cls === "commit" && (
        <svg viewBox="0 0 80 18" width="80" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">a3f4c2b</text>
        </svg>
      )}
      {item.cls === "angle" && (
        <svg viewBox="0 0 80 18" width="80" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">&lt;/div&gt;</text>
        </svg>
      )}
      {item.cls === "prompt" && (
        <svg viewBox="0 0 50 18" width="50" height="18">
          <polyline points="2,4 12,9 2,14" fill="none" stroke="currentColor" stroke-width="1.4" />
          <line x1="16" y1="15" x2="34" y2="15" stroke="currentColor" stroke-width="1.4" />
        </svg>
      )}
      {item.cls === "spread" && (
        <svg viewBox="0 0 80 18" width="80" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">...args</text>
        </svg>
      )}
      {item.cls === "null" && (
        <svg viewBox="0 0 44 18" width="44" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="12" fill="currentColor">null</text>
        </svg>
      )}
      {item.cls === "key" && (
        <svg viewBox="0 0 50 22" width="50" height="22">
          <rect x="1" y="4" width="48" height="14" fill="none" stroke="currentColor" stroke-width="1.2" rx="1" />
          <text x="25" y="14" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="9" fill="currentColor">TAB</text>
        </svg>
      )}
      {item.cls === "pipe" && (
        <svg viewBox="0 0 50 18" width="50" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="12" fill="currentColor">x |&gt; f</text>
        </svg>
      )}
      {item.cls === "hex" && (
        <svg viewBox="0 0 70 18" width="70" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">0xFF4A</text>
        </svg>
      )}
      {item.cls === "binary" && (
        <svg viewBox="0 0 90 18" width="90" height="18">
          <text x="0" y="13" font-family="IBM Plex Mono, monospace" font-size="10" fill="currentColor">10110101</text>
        </svg>
      )}
      {item.cls === "chip" && (
        <svg viewBox="0 0 60 40" width="60" height="40">
          <rect x="10" y="8" width="40" height="24" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="14" cy="12" r="1.2" fill="currentColor" />
          <line x1="18" y1="8" x2="18" y2="4" stroke="currentColor" stroke-width="1.2" />
          <line x1="24" y1="8" x2="24" y2="4" stroke="currentColor" stroke-width="1.2" />
          <line x1="30" y1="8" x2="30" y2="4" stroke="currentColor" stroke-width="1.2" />
          <line x1="36" y1="8" x2="36" y2="4" stroke="currentColor" stroke-width="1.2" />
          <line x1="42" y1="8" x2="42" y2="4" stroke="currentColor" stroke-width="1.2" />
          <line x1="18" y1="32" x2="18" y2="36" stroke="currentColor" stroke-width="1.2" />
          <line x1="24" y1="32" x2="24" y2="36" stroke="currentColor" stroke-width="1.2" />
          <line x1="30" y1="32" x2="30" y2="36" stroke="currentColor" stroke-width="1.2" />
          <line x1="36" y1="32" x2="36" y2="36" stroke="currentColor" stroke-width="1.2" />
          <line x1="42" y1="32" x2="42" y2="36" stroke="currentColor" stroke-width="1.2" />
          <text x="30" y="23" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="6" fill="currentColor">U7</text>
        </svg>
      )}
      {item.cls === "register" && (
        <svg viewBox="0 0 80 20" width="80" height="20">
          <rect x="0" y="4" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="12" y="4" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="24" y="4" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="36" y="4" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="48" y="4" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="60" y="4" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1" />
          <text x="5" y="13" font-family="IBM Plex Mono, monospace" font-size="8" fill="currentColor">1</text>
          <text x="17" y="13" font-family="IBM Plex Mono, monospace" font-size="8" fill="currentColor">0</text>
          <text x="29" y="13" font-family="IBM Plex Mono, monospace" font-size="8" fill="currentColor">1</text>
          <text x="41" y="13" font-family="IBM Plex Mono, monospace" font-size="8" fill="currentColor">1</text>
          <text x="53" y="13" font-family="IBM Plex Mono, monospace" font-size="8" fill="currentColor">0</text>
          <text x="65" y="13" font-family="IBM Plex Mono, monospace" font-size="8" fill="currentColor">1</text>
        </svg>
      )}
      {item.cls === "floppy" && (
        <svg viewBox="0 0 30 30" width="30" height="30">
          <rect x="2" y="2" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.2" />
          <rect x="7" y="2" width="16" height="9" fill="none" stroke="currentColor" stroke-width="1.2" />
          <rect x="9" y="16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.2" />
          <line x1="19" y1="4" x2="19" y2="9" stroke="currentColor" stroke-width="1.2" />
        </svg>
      )}
      {item.cls === "node" && (
        <svg viewBox="0 0 40 40" width="40" height="40">
          <line x1="20" y1="0" x2="20" y2="40" stroke="currentColor" stroke-width="1.2" />
          <line x1="0" y1="20" x2="40" y2="20" stroke="currentColor" stroke-width="1.2" />
          <circle cx="20" cy="20" r="2.5" fill="currentColor" />
        </svg>
      )}
      {item.cls === "browser" && (
        <svg viewBox="0 0 54 40" width="54" height="40">
          <rect x="1" y="1" width="52" height="38" fill="none" stroke="currentColor" stroke-width="1.2" />
          <line x1="1" y1="10" x2="53" y2="10" stroke="currentColor" stroke-width="1" />
          <circle cx="6" cy="5.5" r="1.3" fill="none" stroke="currentColor" stroke-width="1" />
          <circle cx="11" cy="5.5" r="1.3" fill="none" stroke="currentColor" stroke-width="1" />
          <circle cx="16" cy="5.5" r="1.3" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="22" y="3" width="28" height="5" fill="none" stroke="currentColor" stroke-width="1" />
          <line x1="5" y1="17" x2="36" y2="17" stroke="currentColor" stroke-width="1" />
          <line x1="5" y1="23" x2="44" y2="23" stroke="currentColor" stroke-width="1" />
          <line x1="5" y1="29" x2="30" y2="29" stroke="currentColor" stroke-width="1" />
          <line x1="5" y1="35" x2="40" y2="35" stroke="currentColor" stroke-width="1" />
        </svg>
      )}
      {item.cls === "cloud" && (
        <svg viewBox="0 0 54 30" width="54" height="30">
          <path d="M13 24 Q4 24 4 17 Q4 10 13 11 Q15 4 24 4 Q33 4 35 13 Q44 12 46 19 Q48 24 41 24 Z" fill="none" stroke="currentColor" stroke-width="1.2" />
        </svg>
      )}
      {item.cls === "azure" && (
        <svg viewBox="0 0 54 40" width="54" height="40">
          <polygon points="27,4 11,30 43,30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
          <line x1="19" y1="23" x2="35" y2="23" stroke="currentColor" stroke-width="1.2" />
          <text x="27" y="38" text-anchor="middle" font-family="IBM Plex Sans, sans-serif" font-size="7" font-weight="600" fill="currentColor" letter-spacing="1">AZURE</text>
        </svg>
      )}
      {item.cls === "aws" && (
        <svg viewBox="0 0 60 36" width="60" height="36">
          <text x="30" y="17" text-anchor="middle" font-family="IBM Plex Sans, sans-serif" font-size="15" font-weight="700" fill="currentColor" letter-spacing="0.5">aws</text>
          <path d="M8 26 Q30 34 52 26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
          <polyline points="47,24 52,26 48,30" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      )}
      {item.cls === "csharp" && (
        <svg viewBox="0 0 44 30" width="44" height="30">
          <text x="0" y="23" font-family="IBM Plex Sans, sans-serif" font-size="22" font-weight="700" fill="currentColor">C#</text>
        </svg>
      )}
      {item.cls === "js" && (
        <svg viewBox="0 0 30 30" width="30" height="30">
          <rect x="1" y="1" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.2" />
          <text x="15" y="22" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="13" font-weight="600" fill="currentColor">JS</text>
        </svg>
      )}
      {item.cls === "ts" && (
        <svg viewBox="0 0 30 30" width="30" height="30">
          <rect x="1" y="1" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.2" />
          <text x="15" y="22" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="13" font-weight="600" fill="currentColor">TS</text>
        </svg>
      )}
      {item.cls === "rust" && (
        <svg viewBox="0 0 40 40" width="40" height="40">
          <circle cx="20" cy="20" r="12" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="20" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1" />
          <line x1="20" y1="2" x2="20" y2="8" stroke="currentColor" stroke-width="1.2" />
          <line x1="20" y1="32" x2="20" y2="38" stroke="currentColor" stroke-width="1.2" />
          <line x1="2" y1="20" x2="8" y2="20" stroke="currentColor" stroke-width="1.2" />
          <line x1="32" y1="20" x2="38" y2="20" stroke="currentColor" stroke-width="1.2" />
          <line x1="7" y1="7" x2="11" y2="11" stroke="currentColor" stroke-width="1.2" />
          <line x1="29" y1="29" x2="33" y2="33" stroke="currentColor" stroke-width="1.2" />
          <line x1="29" y1="11" x2="33" y2="7" stroke="currentColor" stroke-width="1.2" />
          <line x1="7" y1="33" x2="11" y2="29" stroke="currentColor" stroke-width="1.2" />
          <text x="20" y="24" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="8" font-weight="700" fill="currentColor">R</text>
        </svg>
      )}
      {item.cls === "docker" && (
        <svg viewBox="0 0 54 30" width="54" height="30">
          <rect x="4"  y="18" width="7" height="7" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="12" y="18" width="7" height="7" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="20" y="18" width="7" height="7" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="12" y="10" width="7" height="7" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="20" y="10" width="7" height="7" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="20" y="2"  width="7" height="7" fill="none" stroke="currentColor" stroke-width="1" />
          <path d="M32 22 Q38 18 44 20 Q46 14 50 16" fill="none" stroke="currentColor" stroke-width="1.2" />
        </svg>
      )}
      {item.cls === "git" && (
        <svg viewBox="0 0 54 30" width="54" height="30">
          <line x1="4" y1="15" x2="50" y2="15" stroke="currentColor" stroke-width="1.2" />
          <path d="M18 15 Q22 15 22 8 L40 8" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="10" cy="15" r="3" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="26" cy="15" r="3" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="42" cy="15" r="3" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="34" cy="8"  r="3" fill="none" stroke="currentColor" stroke-width="1.2" />
        </svg>
      )}
      {item.cls === "k8s" && (
        <svg viewBox="0 0 40 40" width="40" height="40">
          <polygon points="20,3 34,12 34,28 20,37 6,28 6,12" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="20" cy="20" r="4" fill="none" stroke="currentColor" stroke-width="1" />
          <line x1="20" y1="3"  x2="20" y2="16" stroke="currentColor" stroke-width="1" />
          <line x1="34" y1="12" x2="24" y2="18" stroke="currentColor" stroke-width="1" />
          <line x1="34" y1="28" x2="24" y2="22" stroke="currentColor" stroke-width="1" />
          <line x1="20" y1="37" x2="20" y2="24" stroke="currentColor" stroke-width="1" />
          <line x1="6"  y1="28" x2="16" y2="22" stroke="currentColor" stroke-width="1" />
          <line x1="6"  y1="12" x2="16" y2="18" stroke="currentColor" stroke-width="1" />
        </svg>
      )}
    </div>
  ))}
</div>

<style>
  .desk-scatter {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 0;
    color: var(--color-ink-3);
    opacity: 0.28;
    overflow: hidden;
  }
  body { position: relative; }
  .ds-item {
    position: absolute;
    display: block;
    will-change: transform;
  }
  .ds-item svg {
    display: block;
    overflow: visible;
  }

  @media (max-width: 1100px) {
    .desk-scatter { display: none; }
  }

  @media (prefers-color-scheme: dark) {
    .desk-scatter { opacity: 0.22; }
  }
</style>
