---
// Paper-mode toggle: cream drafting paper ↔ cyanotype blueprint.
---

<span class="mode" role="group" aria-label="Paper mode">
  <button type="button" data-mode="light" aria-pressed="true">Cream</button>
  <button type="button" data-mode="dark" aria-pressed="false">Blueprint</button>
</span>

<style>
  .mode {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--color-ink);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1;
  }
  .mode button {
    background: transparent;
    color: var(--color-ink-2);
    border: none;
    padding: 5px 9px;
    cursor: pointer;
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
  }
  .mode button + button {
    border-left: 1px solid var(--color-ink);
  }
  .mode button[aria-pressed="true"] {
    background: var(--color-ink);
    color: var(--color-desk);
  }
  .mode button[aria-pressed="false"]:hover {
    color: var(--color-ink);
  }
</style>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var btns = document.querySelectorAll(".mode button");

    function apply(mode, persist) {
      root.setAttribute("data-theme", mode);
      btns.forEach(function (b) {
        b.setAttribute("aria-pressed", b.dataset.mode === mode ? "true" : "false");
      });
      var favicon = document.getElementById("favicon");
      if (favicon) {
        favicon.setAttribute("href", mode === "dark" ? "/favicon-blueprint.svg" : "/favicon-cream.svg");
      }
      if (persist) {
        try { localStorage.setItem("theme", mode); } catch (e) {}
      }
    }

    function initial() {
      try {
        var stored = localStorage.getItem("theme");
        if (stored === "light" || stored === "dark") return stored;
      } catch (e) {}
      return window.matchMedia &&
        window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }

    btns.forEach(function (b) {
      b.addEventListener("click", function () { apply(b.dataset.mode, true); });
    });

    apply(initial(), false);
  })();
</script>
