---
import Navigation from "./Navigation.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="sheet-head">
  <div class="dwg-no">
    DWG. <b>A-001</b> · REV <b>04</b>
  </div>
  <a href="/" class="nameplate">
    <span class="name">Afroze Amjad</span>
    <span class="role">Solution Architect</span>
  </a>
  <div class="head-right">
    <Navigation />
    <ThemeToggle />
  </div>
</header>

<style>
  .sheet-head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 6px 0 14px;
    border-bottom: 1.5px solid var(--color-ink);
    margin-bottom: 32px;
  }

  .dwg-no {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .dwg-no b { color: var(--color-ink); font-weight: 600; }

  .nameplate {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    border-bottom: none;
    line-height: 1.1;
  }
  .nameplate:hover { border-bottom: none; }
  .nameplate .name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .nameplate .role {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    margin-top: 4px;
  }

  .head-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
  }

  /* Stack on small screens — keep the drafting cadence */
  @media (max-width: 820px) {
    .sheet-head {
      grid-template-columns: 1fr;
      justify-items: start;
      text-align: left;
      gap: 12px;
    }
    .nameplate {
      align-items: flex-start;
      text-align: left;
    }
    .head-right {
      justify-content: flex-start;
      flex-wrap: wrap;
    }
  }
</style>
