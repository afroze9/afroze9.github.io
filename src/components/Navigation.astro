---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Index" },
  { href: "/about/", label: "About" },
  { href: "/experience/", label: "Experience" },
  { href: "/projects/", label: "Projects" },
  { href: "/opensource/", label: "OSS" },
  { href: "/writing/", label: "Writing" },
  { href: "/search/", label: "Search" },
];

function isActive(href: string): boolean {
  if (href === "/") {
    return currentPath === "/" || currentPath === "";
  }
  return currentPath.startsWith(href);
}

const pad = (n: number) => n.toString().padStart(2, "0");
---

<nav class="navigation" aria-label="Primary">
  <ul>
    {links.map((link, i) => (
      <li>
        <a
          href={link.href}
          class:list={[{ active: isActive(link.href) }]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          <span class="num">[{pad(i + 1)}]</span>
          <span class="label">{link.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .navigation ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
  }
  .navigation li { margin: 0; }

  .navigation a {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.12s ease, color 0.12s ease;
  }
  .navigation a:hover { border-bottom-color: var(--color-ink); }

  .navigation a.active {
    color: var(--color-cyan);
    border-bottom-color: var(--color-cyan);
  }

  .navigation .num { color: var(--color-ink-3); }
  .navigation a.active .num { color: var(--color-cyan); }

  @media (max-width: 820px) {
    .navigation ul { gap: 6px 14px; }
  }
  @media (max-width: 480px) {
    .navigation ul { gap: 4px 12px; }
    .navigation a { font-size: 10.5px; }
  }
</style>
