---
import BaseLayout from "../../layouts/BaseLayout.astro";

const description = "TerraStudio — a visual infrastructure diagram builder. Drag-and-drop Azure and AWS resources, configure visually, and export production-ready Terraform code.";

const features = [
  {
    icon: "canvas",
    title: "Visual Drag & Drop",
    description: "Build infrastructure diagrams on an interactive canvas. Drop Azure and AWS resources, connect them visually, and see your architecture take shape.",
  },
  {
    icon: "terraform",
    title: "Terraform Code Generation",
    description: "Export production-ready HCL code from your diagrams. Modules, variables, and tfvars — generated automatically from your visual design.",
  },
  {
    icon: "cost",
    title: "Cost Estimation",
    description: "See estimated monthly costs as you design. Breakdown by resource, container, and module — before you deploy a single resource.",
  },
  {
    icon: "modules",
    title: "Module System",
    description: "Define reusable Terraform modules visually. Create a module template once, instantiate it across your diagram with different configurations.",
  },
  {
    icon: "plugins",
    title: "60+ Cloud Resources",
    description: "Azure networking, compute, storage, databases, AI services, and AWS support. Each resource has schema-driven properties and official icons.",
  },
  {
    icon: "cli",
    title: "CLI & MCP Server",
    description: "Headless project management via CLI. AI assistant integration through the built-in MCP server for automated infrastructure workflows.",
  },
];

const stats = [
  { value: "320+", label: "Commits" },
  { value: "60+", label: "Resources" },
  { value: "33", label: "Days Built" },
  { value: "v0.48", label: "Latest" },
];

const techStack = [
  { name: "Svelte", role: "UI Framework" },
  { name: "TypeScript", role: "Language" },
  { name: "Tauri 2", role: "Desktop Runtime" },
  { name: "Rust", role: "Backend" },
  { name: "Terraform", role: "IaC Target" },
  { name: "Svelte Flow", role: "Canvas" },
];

const milestones = [
  { version: "0.1", date: "Feb 20", title: "First canvas with drag-and-drop" },
  { version: "0.4", date: "Feb 26", title: "Edge styling system" },
  { version: "0.5", date: "Feb 26", title: "Cost estimation panel" },
  { version: "0.6", date: "Feb 27", title: "MCP server for AI integration" },
  { version: "0.15", date: "Mar 1", title: "Module template reuse" },
  { version: "0.21", date: "Mar 6", title: "AWS plugin support" },
  { version: "0.28", date: "Mar 7", title: "Internationalization — 6 languages" },
  { version: "0.33", date: "Mar 8", title: "Dependency graph view" },
  { version: "0.39", date: "Mar 8", title: "Multi-subscription HCL generation" },
  { version: "0.48", date: "Mar 23", title: "Interactive CLI wizard" },
];

const pad = (n: number) => n.toString().padStart(2, "0");
---

<BaseLayout title="TerraStudio" description={description}>
  <!-- Intro / title block -->
  <section class="intro">
    <div class="kicker">◊ Detail Sheet · PRJ-01 · TerraStudio</div>
    <div class="title-row">
      <h1>Terra<span class="accent">Studio</span></h1>
      <span class="badge">Open Source</span>
    </div>
    <p class="tagline">Visual Infrastructure as Code</p>
    <p class="lead">
      Design cloud infrastructure by dragging and dropping resources onto a canvas.
      Connect them visually, configure properties, and export production-ready Terraform code.
    </p>

    <div class="actions">
      <a id="download-btn" href="https://github.com/afroze9/TerraStudio/releases/latest" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="btn-icon">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        <span id="download-label">Download</span>
      </a>
      <a href="https://github.com/afroze9/TerraStudio" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="currentColor" class="btn-icon">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        GitHub
      </a>
    </div>

    <div class="summary">
      <div class="summary-lbl">As-built totals</div>
      <div class="summary-grid">
        {stats.map((s) => (
          <div class="summary-dim">
            <span class="val">{s.value}</span>
            <span class="line"></span>
            <span class="lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Screenshot -->
  <section>
    <header class="section-head">
      <span class="tag">§ 01</span>
      <h2>Canvas View</h2>
      <span class="rule"></span>
      <span class="scale">Fig. A · Scale 1:1</span>
    </header>
    <figure class="screenshot">
      <div class="screenshot-head">
        <span class="sh-code">FIG-A · PRODUCT SCREENSHOT</span>
        <span class="sh-meta">v0.48</span>
      </div>
      <div class="screenshot-body">
        <img src="/projects/terrastudio-screenshot.png" alt="TerraStudio — visual infrastructure designer with Azure resources on canvas" loading="eager" />
      </div>
    </figure>
  </section>

  <!-- Features -->
  <section>
    <header class="section-head">
      <span class="tag">§ 02</span>
      <h2>Features</h2>
      <span class="rule"></span>
      <span class="scale">6 modules · Scale 1:25</span>
    </header>
    <div class="features-grid">
      {features.map((feature, i) => (
        <article class="feature">
          <div class="feature-head">
            <span class="feature-code">FT-{pad(i + 1)}</span>
            <span class="feature-pip">◊</span>
          </div>
          <div class="feature-body">
            <div class="feature-icon">
              {feature.icon === "canvas" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <rect x="3" y="3" width="7" height="7" />
                  <rect x="14" y="3" width="7" height="7" />
                  <rect x="3" y="14" width="7" height="7" />
                  <rect x="14" y="14" width="7" height="7" />
                </svg>
              )}
              {feature.icon === "terraform" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <polyline points="16 18 22 12 16 6" />
                  <polyline points="8 6 2 12 8 18" />
                  <line x1="14" y1="4" x2="10" y2="20" />
                </svg>
              )}
              {feature.icon === "cost" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
              )}
              {feature.icon === "modules" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <rect x="2" y="2" width="8" height="8" />
                  <rect x="14" y="2" width="8" height="8" />
                  <rect x="2" y="14" width="8" height="8" />
                  <path d="M14 14h8v8h-8z" stroke-dasharray="2 2" />
                </svg>
              )}
              {feature.icon === "plugins" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
                </svg>
              )}
              {feature.icon === "cli" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <polyline points="4 17 10 11 4 5" />
                  <line x1="12" y1="19" x2="20" y2="19" />
                </svg>
              )}
            </div>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Tech Stack -->
  <section>
    <header class="section-head">
      <span class="tag">§ 03</span>
      <h2>Built With</h2>
      <span class="rule"></span>
      <span class="scale">Bill of materials</span>
    </header>
    <div class="tech-grid">
      {techStack.map((tech, i) => (
        <div class="tech-item">
          <span class="tech-code">M-{pad(i + 1)}</span>
          <span class="tech-name">{tech.name}</span>
          <span class="tech-role">{tech.role}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Milestones -->
  <section>
    <header class="section-head">
      <span class="tag">§ 04</span>
      <h2>Development Timeline</h2>
      <span class="rule"></span>
      <span class="scale">First commit → v0.48 · 33 days</span>
    </header>
    <div class="milestones">
      {milestones.map((m, i) => (
        <article class="m-row">
          <div class="m-marker">
            <span class="m-version">v{m.version}</span>
            <span class="m-node"></span>
          </div>
          <div class="m-card">
            <div class="m-head">
              <span class="m-code">REV-{pad(i + 1)}</span>
              <span class="m-date">{m.date}</span>
            </div>
            <div class="m-body">
              <p>{m.title}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="timeline-cta">
      <a href="/projects/terrastudio/timeline.html" target="_blank" class="cta-link">
        <span>View Interactive Timeline — 320 commits visualized</span>
        <span class="arrow">→</span>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-block">
    <div class="cta-head">
      <span class="cta-tag">§ 05 · Distribution</span>
      <span class="cta-rule"></span>
    </div>
    <div class="cta-body">
      <div>
        <h2>Try TerraStudio</h2>
        <p>Available for Windows, macOS, and Linux.</p>
      </div>
      <div class="cta-actions">
        <a href="https://github.com/afroze9/TerraStudio/releases/latest" class="cta-link solid">
          Download Latest Release
        </a>
        <a href="https://github.com/afroze9/TerraStudio" target="_blank" rel="noopener noreferrer" class="cta-link">
          View Source on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('download-btn');
  const label = document.getElementById('download-label');
  if (btn && label) {
    const ua = navigator.userAgent.toLowerCase();
    if (ua.includes('win')) {
      label.textContent = 'Download for Windows';
    } else if (ua.includes('mac')) {
      label.textContent = 'Download for macOS';
    } else if (ua.includes('linux')) {
      label.textContent = 'Download for Linux';
    }
  }
</script>

<style>
  /* Intro */
  .intro {
    padding-top: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .intro .kicker {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin-bottom: 12px;
  }
  .intro .title-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .intro h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 4.8vw, 60px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin: 0;
    color: var(--color-ink);
  }
  .intro .accent { color: var(--color-cyan); }
  .intro .badge {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-cyan);
    padding: 4px 10px;
    border: 1px solid var(--color-cyan);
    background: var(--color-paper-2);
  }
  .intro .tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    margin: 0 0 14px;
  }
  .intro .lead {
    font-size: var(--font-size-lg);
    color: var(--color-ink-2);
    max-width: 70ch;
    margin: 0 0 24px;
    line-height: 1.55;
  }

  /* Action buttons — drafting style: square borders, mono, hover = ink fill */
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1.5px solid var(--color-ink);
    transition: background 0.12s ease, color 0.12s ease;
    cursor: pointer;
  }
  .btn-icon { width: 14px; height: 14px; flex-shrink: 0; }
  .btn-primary {
    background: var(--color-ink);
    color: var(--color-paper);
  }
  .btn-primary:hover {
    background: var(--color-cyan);
    border-color: var(--color-cyan);
    color: var(--color-paper);
    border-bottom-color: var(--color-cyan);
  }
  .btn-secondary {
    background: var(--color-paper);
    color: var(--color-ink);
  }
  .btn-secondary:hover {
    background: var(--color-ink);
    color: var(--color-paper);
    border-bottom-color: var(--color-ink);
  }

  /* Summary — as-built totals strip */
  .summary {
    padding: 22px 26px 20px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    position: relative;
  }
  .summary-lbl {
    position: absolute;
    top: -10px;
    left: 18px;
    background: var(--color-paper);
    padding: 0 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  @media (max-width: 720px) {
    .summary-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
  }
  .summary-dim {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .summary-dim .val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 36px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .summary-dim .line {
    height: 1px;
    background: var(--color-ink);
    position: relative;
    margin: 8px 0 6px;
  }
  .summary-dim .line::before,
  .summary-dim .line::after {
    content: "";
    position: absolute;
    top: -4px;
    width: 1px;
    height: 9px;
    background: var(--color-ink);
  }
  .summary-dim .line::before { left: 0; }
  .summary-dim .line::after { right: 0; }
  .summary-dim .lbl {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }

  /* Screenshot — framed figure with chrome head */
  .screenshot {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    margin: 0;
  }
  .screenshot-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
    background: var(--color-chrome-bg);
    color: var(--color-chrome-fg);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .sh-code { color: var(--color-chrome-accent); }
  .screenshot-body {
    padding: 14px;
    background: var(--color-paper-2);
  }
  .screenshot-body img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-ink);
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .features-grid { grid-template-columns: 1fr; } }

  .feature {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    display: flex;
    flex-direction: column;
  }
  .feature-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 14px;
    border-bottom: 1px dashed var(--color-ink-3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .feature-code { color: var(--color-cyan); }
  .feature-pip { color: var(--color-ink-2); }

  .feature-body {
    padding: 20px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .feature-icon {
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    display: grid;
    place-items: center;
    color: var(--color-cyan);
  }
  .feature-icon svg { width: 22px; height: 22px; }
  .feature-body h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.15;
  }
  .feature-body p {
    font-size: var(--font-size-sm);
    line-height: 1.55;
    color: var(--color-ink-2);
    margin: 0;
  }

  /* Tech stack — bill of materials */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  @media (max-width: 720px) { .tech-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 420px) { .tech-grid { grid-template-columns: 1fr; } }

  .tech-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: baseline;
    padding: 12px 14px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
  }
  .tech-code {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-cyan);
  }
  .tech-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .tech-role {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }

  /* Milestones — revision log with diamond nodes */
  .milestones {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 22px;
  }
  .milestones::before {
    content: "";
    position: absolute;
    left: 43px;
    top: 10px;
    bottom: 10px;
    width: 1px;
    background-image: linear-gradient(
      to bottom,
      var(--color-ink-3) 50%,
      transparent 50%
    );
    background-size: 1px 8px;
    background-repeat: repeat-y;
    z-index: 0;
  }
  .m-row {
    display: grid;
    grid-template-columns: 86px 1fr;
    gap: 18px;
    align-items: start;
    position: relative;
  }
  .m-marker {
    padding-top: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    position: relative;
    z-index: 1;
  }
  .m-version {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-cyan);
    font-weight: 600;
    padding: 3px 7px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
  }
  .m-node {
    width: 8px;
    height: 8px;
    background: var(--color-ink);
    transform: rotate(45deg);
  }
  .m-card {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
  }
  .m-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 14px;
    background: var(--color-chrome-bg);
    color: var(--color-chrome-fg);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .m-code { color: var(--color-chrome-accent); }
  .m-body { padding: 12px 16px 14px; }
  .m-body p {
    font-size: var(--font-size-sm);
    line-height: 1.5;
    color: var(--color-ink);
    margin: 0;
  }

  @media (max-width: 600px) {
    .m-row { grid-template-columns: 64px 1fr; gap: 12px; }
    .m-version { font-size: 10px; padding: 2px 5px; }
    .milestones::before { left: 32px; }
  }

  .timeline-cta {
    display: flex;
    justify-content: center;
  }

  /* Drafting-style link buttons — shared */
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
    padding: 10px 16px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    text-decoration: none;
    transition: background 0.12s ease, color 0.12s ease;
