---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const description = "Project case studies by Afroze Amjad. AI copilots, cloud architecture, and enterprise platform solutions.";

const projects = await getCollection("projects");
const featuredProjects = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const otherProjects = projects
  .filter((p) => !p.data.featured)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const categories = [
  { id: "ai", label: "AI / ML" },
  { id: "architecture", label: "Architecture" },
  { id: "platform", label: "Platform" },
  { id: "devops", label: "DevOps" },
  { id: "integration", label: "Integration" },
];

const categoryLabels: Record<string, string> = {
  ai: "AI / ML",
  architecture: "Architecture",
  platform: "Platform",
  devops: "DevOps",
  integration: "Integration",
};

const pad = (n: number) => n.toString().padStart(2, "0");
---

<BaseLayout title="Projects" description={description}>
  <section class="intro">
    <div class="kicker">◊ Sheet 3 of 4 · Project index</div>
    <h1>Projects</h1>
    <p class="sub">
      A selection of projects spanning AI systems, cloud architecture, and
      enterprise platforms. Each a distinct problem, measured to completion.
    </p>
  </section>

  <section class="legend-wrap">
    <div class="legend">
      <span class="legend-lbl">Legend</span>
      <div class="legend-items">
        {categories.map((cat) => (
          <span class={`legend-item cat-${cat.id}`}>
            <span class="legend-swatch"></span>
            <span class="legend-text">{cat.label}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 01</span>
      <h2>Featured Work</h2>
      <span class="rule"></span>
      <span class="scale">Scale 1:25</span>
    </header>
    <div class="dwg-grid featured-grid">
      {featuredProjects.map((project, i) => (
        <article class="dwg-card featured">
          <div class="dwg-head">
            <span class="dwg-code">
              <span>PRJ-{pad(i + 1)}</span>
              <span class="sep">·</span>
              <span class={`cat-swatch cat-${project.data.category}`} aria-hidden="true"></span>
              <span class="cat-label">{categoryLabels[project.data.category]}</span>
            </span>
            <span class="dwg-date">{project.data.date} ◊</span>
          </div>
          <div class="dwg-body">
            <div class="title-row">
              <h3>
                {project.slug === "terrastudio" ? (
                  <a href="/projects/terrastudio/" class="project-link">{project.data.title}</a>
                ) : (
                  project.data.title
                )}
              </h3>
              <p class="role">{project.data.role}</p>
            </div>

            {project.data.image && (
              <div class="card-image">
                {project.slug === "terrastudio" ? (
                  <a href="/projects/terrastudio/">
                    <img src={project.data.image} alt={`${project.data.title} screenshot`} loading="lazy" />
                  </a>
                ) : (
                  <img src={project.data.image} alt={`${project.data.title} screenshot`} loading="lazy" />
                )}
              </div>
            )}

            <div class="specs specs-2col">
              <div class="spec">
                <span class="spec-lbl">§ Challenge</span>
                <p>{project.data.problem}</p>
              </div>
              <div class="spec">
                <span class="spec-lbl">§ Solution</span>
                <p>{project.data.solution}</p>
              </div>
            </div>
          </div>

          <footer class="dwg-foot">
            <div class="impact-dim">
              <span class="impact-lbl">Impact</span>
              <span class="impact-rule"></span>
              <span class="impact-val">{project.data.impact}</span>
            </div>
            <div class="foot-right">
              {project.slug === "terrastudio" && (
                <a href="/projects/terrastudio/" class="view-link">View Detail Sheet →</a>
              )}
              {project.data.technologies && project.data.technologies.length > 0 && (
                <div class="tech">
                  {project.data.technologies.map((tech) => (
                    <span class="tech-tag">{tech}</span>
                  ))}
                </div>
              )}
            </div>
          </footer>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 02</span>
      <h2>More Projects</h2>
      <span class="rule"></span>
      <span class="scale">Scale 1:50</span>
    </header>
    <div class="dwg-grid other-grid">
      {otherProjects.map((project, i) => (
        <article class="dwg-card">
          <div class="dwg-head">
            <span class="dwg-code">
              <span>PRJ-{pad(featuredProjects.length + i + 1)}</span>
              <span class="sep">·</span>
              <span class={`cat-swatch cat-${project.data.category}`} aria-hidden="true"></span>
              <span class="cat-label">{categoryLabels[project.data.category]}</span>
            </span>
            <span class="dwg-date">{project.data.date} ◊</span>
          </div>
          <div class="dwg-body">
            <div class="title-row">
              <h3>{project.data.title}</h3>
              <p class="role">{project.data.role}</p>
            </div>
            <div class="specs">
              <div class="spec">
                <span class="spec-lbl">§ Challenge</span>
                <p>{project.data.problem}</p>
              </div>
              <div class="spec">
                <span class="spec-lbl">§ Solution</span>
                <p>{project.data.solution}</p>
              </div>
            </div>
          </div>
          <footer class="dwg-foot">
            <div class="impact-dim">
              <span class="impact-lbl">Impact</span>
              <span class="impact-rule"></span>
              <span class="impact-val">{project.data.impact}</span>
            </div>
            {project.data.technologies && project.data.technologies.length > 0 && (
              <div class="tech">
                {project.data.technologies.map((tech) => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
            )}
          </footer>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-block">
    <div class="cta-head">
      <span class="cta-tag">§ 03 · Cross-reference</span>
      <span class="cta-rule"></span>
    </div>
    <div class="cta-body">
      <div>
        <h2>Open Source Work</h2>
        <p>Personal projects, experiments, and contributions on GitHub.</p>
      </div>
      <a href="/opensource/" class="cta-link">See Sheet 4 →</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Intro */
  .intro {
    padding-top: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .intro .kicker {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin-bottom: 12px;
  }
  .intro h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: var(--color-ink);
  }
  .intro .sub {
    font-size: var(--font-size-lg);
    color: var(--color-ink-2);
    max-width: 70ch;
    margin: 0;
  }

  /* Legend */
  .legend-wrap {
    margin-bottom: var(--space-2xl);
  }
  .legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 20px;
    padding: 12px 16px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper-2);
  }
  .legend-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    padding-right: 10px;
    border-right: 1px solid var(--color-ink-3);
  }
  .legend-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .legend-swatch {
    width: 11px;
    height: 11px;
    border: 1px solid var(--color-ink);
    background: var(--cat-color, var(--color-ink-3));
  }
  .legend-item.cat-ai { --cat-color: var(--color-cat-ai); }
  .legend-item.cat-architecture { --cat-color: var(--color-cat-arch); }
  .legend-item.cat-platform { --cat-color: var(--color-cat-platform); }
  .legend-item.cat-devops { --cat-color: var(--color-cat-devops); }
  .legend-item.cat-integration { --cat-color: var(--color-cat-integration); }

  /* Drawing card grid */
  .dwg-grid {
    display: grid;
    gap: 28px;
  }
  .featured-grid { grid-template-columns: 1fr; }
  .other-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 820px) {
    .other-grid { grid-template-columns: 1fr; }
  }

  /* Drawing card — drafting detail block */
  .dwg-card {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* Featured cards get corner marks and a heavier frame */
  .dwg-card.featured {
    border-width: 2px;
    box-shadow: 0 1px 0 rgba(20, 35, 59, 0.08),
                0 10px 32px -18px rgba(20, 35, 59, 0.28);
  }
  .dwg-card.featured::before,
  .dwg-card.featured::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
  }
  .dwg-card.featured::before { top: -8px; left: -8px; }
  .dwg-card.featured::after { bottom: -8px; right: -8px; }

  /* Head strip — mono code + category swatch + date. Chrome tokens stay
     dark-on-light in both themes so the cyan accent is always legible. */
  .dwg-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 10px 18px;
    background: var(--color-chrome-bg);
    color: var(--color-chrome-fg);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .dwg-code {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }
  .dwg-code .sep { color: var(--color-chrome-fg); opacity: 0.5; }
  .dwg-head .cat-label { color: var(--color-chrome-accent); }

  /* Category swatch — same colors as the legend, with a cream outline so
     it reads on the dark chrome bar. */
  .cat-swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--cat-color, var(--color-ink-3));
    border: 1px solid var(--color-chrome-fg);
    flex-shrink: 0;
  }
  .cat-swatch.cat-ai { --cat-color: var(--color-cat-ai); }
  .cat-swatch.cat-architecture { --cat-color: var(--color-cat-arch); }
  .cat-swatch.cat-platform { --cat-color: var(--color-cat-platform); }
  .cat-swatch.cat-devops { --cat-color: var(--color-cat-devops); }
  .cat-swatch.cat-integration { --cat-color: var(--color-cat-integration); }

  .dwg-body {
    padding: 22px 24px 18px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex: 1;
  }

  .title-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-bottom: 14px;
    border-bottom: 1px dashed var(--color-ink-3);
  }
  .title-row h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 26px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0;
    line-height: 1;
  }
  .dwg-card.featured .title-row h3 { font-size: 32px; }
  .other-grid .title-row h3 { font-size: 20px; }

  .role {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    margin: 0;
  }
  .project-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 2px solid transparent;
  }
  .project-link:hover {
    color: var(--color-cyan);
    border-bottom-color: var(--color-cyan);
  }

  .card-image {
    border: 1px solid var(--color-ink);
    background: var(--color-paper-2);
    padding: 6px;
  }
  .card-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .specs { display: grid; gap: 16px; }
  .specs-2col { grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 640px) {
    .specs-2col { grid-template-columns: 1fr; gap: 16px; }
  }

  .spec-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-cyan);
    display: block;
    margin-bottom: 6px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--color-ink-3);
  }
  .spec p {
    font-size: var(--font-size-base);
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0;
  }
  .other-grid .spec p { font-size: var(--font-size-sm); }

  /* Footer strip — impact dimension + tech tags */
  .dwg-foot {
    margin-top: auto;
    padding: 16px 24px 18px;
    border-top: 1px solid var(--color-ink);
    background: var(--color-paper-2);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  /* Row layout only on featured cards (wider), and wrap so impact and
     tech stack cleanly when they run out of room rather than overflowing. */
  .dwg-card.featured .dwg-foot {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px 24px;
  }

  .impact-dim {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    min-width: 0;
    flex: 1 1 200px;
  }
  .impact-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }
  .impact-rule {
    height: 1px;
    background: var(--color-ink);
    position: relative;
  }
  .impact-rule::before,
  .impact-rule::after {
    content: "";
    position: absolute;
    top: -4px;
    width: 1px;
    height: 9px;
    background: var(--color-ink);
  }
  .impact-rule::before { left: 0; }
  .impact-rule::after { right: 0; }
  .impact-val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-cyan);
    white-space: nowrap;
  }
  .dwg-card.featured .impact-val { font-size: 24px; }

  .foot-right {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
  }
  @media (min-width: 720px) {
    .foot-right { align-items: flex-end; }
  }

  .view-link {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cyan);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .view-link:hover { border-bottom-color: var(--color-cyan); }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .tech-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    padding: 3px 7px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
  }

  /* Cross-reference CTA */
  .cta-block {
    margin-top: var(--space-2xl);
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    position: relative;
  }
  .cta-block::before {
    content: "";
    position: absolute;
    inset: 6px;
    border: 1px solid var(--color-ink-3);
    pointer-events: none;
  }
  .cta-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 20px;
    border-bottom: 1px dashed var(--color-ink-3);
    position: relative;
    z-index: 1;
  }
  .cta-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-cyan);
    text-transform: uppercase;
  }
  .cta-rule {
    flex: 1;
    height: 1px;
    background: var(--color-ink-3);
  }
  .cta-body {
    padding: 22px 26px 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px) {
    .cta-body { flex-direction: row; align-items: center; gap: 24px; }
  }
  .cta-body h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 26px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0 0 4px;
    line-height: 1;
  }
  .cta-body p {
    color: var(--color-ink-2);
    font-size: var(--font-size-sm);
    margin: 0;
  }
  .cta-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
    padding: 10px 16px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    text-decoration: none;
    transition: background 0.12s ease, color 0.12s ease;
    flex-shrink: 0;
  }
  .cta-link:hover {
    background: var(--color-ink);
    color: var(--color-paper);
  }
</style>
