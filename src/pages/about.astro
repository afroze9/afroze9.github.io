---
import BaseLayout from "../layouts/BaseLayout.astro";

const description =
  "Philosophy and background of Afroze Amjad, Solution Architect focused on GenAI, cloud architecture, and engineering leadership.";

const principles = [
  {
    title: "Simplicity over cleverness",
    description:
      "The best code is the code you don't have to think about. Reduce cognitive load, make intent obvious.",
  },
  {
    title: "Outcomes over technology",
    description:
      "Technology serves business goals. Choose tools that solve problems, not tools that are interesting.",
  },
  {
    title: "Constraints breed creativity",
    description:
      "Embrace limitations. They focus thinking and lead to elegant solutions.",
  },
  {
    title: "Build for change",
    description:
      "Requirements evolve. Architecture should make change cheap, not prevent it.",
  },
];

const timeline = [
  { year: "2014", event: "Graduated from NUST with Electrical Engineering degree" },
  { year: "2014", event: "Joined CureMD in healthcare technology" },
  { year: "2018", event: "Transitioned from analyst to engineering roles" },
  { year: "2020", event: "Led engineering teams and automation initiatives" },
  { year: "2021", event: "First architecture role, API modernization" },
  { year: "2022", event: "Joined Confiz, expanded to enterprise clients" },
  { year: "2024", event: "AI-first projects for Fortune 500 companies" },
  { year: "2025", event: "Senior Architect, Engineering Council lead" },
  { year: "2026", event: "Associate Director Engineering, AI Strategy & Enterprise Solutions" },
];

const interests = [
  { label: "AI / ML Systems", icon: "brain", code: "INT-01" },
  { label: "Distributed Systems", icon: "network", code: "INT-02" },
  { label: "Developer Experience", icon: "code", code: "INT-03" },
  { label: "Technical Writing", icon: "pen", code: "INT-04" },
];

const pad = (n: number) => n.toString().padStart(2, "0");
---

<BaseLayout title="About" description={description}>
  <section class="intro">
    <div class="kicker">◊ Sheet 2 of 4 · Operator profile</div>
    <h1>About</h1>
    <p class="lead">
      I build systems that are simple to understand, easy to maintain, and
      resilient under pressure.
    </p>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 01</span>
      <h2>How I Think</h2>
      <span class="rule"></span>
      <span class="scale">Guiding principles</span>
    </header>
    <div class="principles-grid">
      {principles.map((p, i) => (
        <article class="principle">
          <div class="principle-head">
            <span class="principle-code">PR-{pad(i + 1)}</span>
            <span class="principle-tag">Note</span>
          </div>
          <div class="principle-body">
            <span class="principle-num">{pad(i + 1)}</span>
            <h3>{p.title}</h3>
            <p>{p.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 02</span>
      <h2>The Path Here</h2>
      <span class="rule"></span>
      <span class="scale">Electrical → Software</span>
    </header>
    <div class="story-content">
      <div class="story-text">
        <p>
          My journey started in Electrical Engineering at NUST, where I
          learned to think in systems and decompose complex problems. I didn't
          plan to become a software architect, but each role naturally led to
          the next.
        </p>
        <p>
          A decade in healthcare technology taught me what reliability really
          means. When your system serves thousands of healthcare providers,
          you learn the cost of downtime and the value of boring, predictable
          architecture.
        </p>
        <p>
          Today, I apply those lessons to AI systems, enterprise platforms,
          and cloud migrations. The technology changes; the principles don't.
        </p>
      </div>
      <aside class="timeline">
        <div class="timeline-lbl">Detail C · Scale 1:1</div>
        <div class="timeline-list">
          {timeline.map((item) => (
            <div class="t-row">
              <span class="t-year">{item.year}</span>
              <span class="t-line"></span>
              <span class="t-event">{item.event}</span>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 03</span>
      <h2>Current Interests</h2>
      <span class="rule"></span>
      <span class="scale">Active threads</span>
    </header>
    <div class="interests-grid">
      {interests.map((item) => (
        <article class="interest">
          <div class="interest-head">
            <span class="interest-code">{item.code}</span>
            <span class="interest-pip">◊</span>
          </div>
          <div class="interest-body">
            <div class="interest-icon">
              {item.icon === "brain" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M12 2a9 9 0 0 0-9 9c0 3.6 2.4 6.5 5.5 7.5.3.1.5.4.5.7v2.8h6v-2.8c0-.3.2-.6.5-.7 3.1-1 5.5-3.9 5.5-7.5a9 9 0 0 0-9-9z" />
                  <path d="M12 2v4M8 6l2 2M16 6l-2 2" />
                </svg>
              )}
              {item.icon === "network" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <circle cx="12" cy="5" r="3" />
                  <circle cx="5" cy="19" r="3" />
                  <circle cx="19" cy="19" r="3" />
                  <line x1="12" y1="8" x2="5" y2="16" />
                  <line x1="12" y1="8" x2="19" y2="16" />
                </svg>
              )}
              {item.icon === "code" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <polyline points="16 18 22 12 16 6" />
                  <polyline points="8 6 2 12 8 18" />
                </svg>
              )}
              {item.icon === "pen" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M12 19l7-7 3 3-7 7-3-3z" />
                  <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z" />
                  <path d="M2 2l7.586 7.586" />
                  <circle cx="11" cy="11" r="2" />
                </svg>
              )}
            </div>
            <span class="interest-label">{item.label}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 04</span>
      <h2>Education</h2>
      <span class="rule"></span>
      <span class="scale">Credential</span>
    </header>
    <article class="edu">
      <div class="edu-head">
        <span class="edu-code">EDU-01 · UNDERGRADUATE</span>
        <span class="edu-year">2010 — 2014</span>
      </div>
      <div class="edu-body">
        <div class="edu-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c0 1.5 2.5 3 6 3s6-1.5 6-3v-5"/>
          </svg>
        </div>
        <div class="edu-content">
          <h3>Bachelor of Electrical Engineering</h3>
          <p class="edu-school">National University of Sciences and Technology (NUST)</p>
          <p class="edu-meta">Islamabad, Pakistan · Class of 2014</p>
        </div>
        <div class="edu-stamp">
          <span class="stamp">Conferred</span>
        </div>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  /* Intro */
  .intro { padding-top: var(--space-md); margin-bottom: var(--space-xl); }
  .intro .kicker {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin-bottom: 12px;
  }
  .intro h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: var(--color-ink);
  }
  .intro .lead {
    font-size: var(--font-size-lg);
    color: var(--color-ink-2);
    max-width: 70ch;
    margin: 0;
    line-height: 1.55;
  }

  /* Principles — spec notes with big number in corner */
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (max-width: 720px) {
    .principles-grid { grid-template-columns: 1fr; }
  }
  .principle {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    display: flex;
    flex-direction: column;
  }
  .principle-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 14px;
    background: var(--color-chrome-bg);
    color: var(--color-chrome-fg);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .principle-code { color: var(--color-chrome-accent); }
  .principle-body {
    padding: 22px 22px 22px;
    position: relative;
    flex: 1;
  }
  .principle-num {
    position: absolute;
    top: 16px;
    right: 18px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 60px;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-paper-2);
    pointer-events: none;
  }
  .principle-body h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0 0 10px;
    padding-right: 60px;
    line-height: 1.1;
  }
  .principle-body p {
    font-size: var(--font-size-sm);
    line-height: 1.55;
    color: var(--color-ink-2);
    margin: 0;
  }

  /* Story — two column with timeline detail sheet */
  .story-content {
    display: grid;
    gap: 28px;
  }
  @media (min-width: 820px) {
    .story-content { grid-template-columns: 1.1fr 1fr; gap: 36px; }
  }
  .story-text p {
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }
  .story-text p:last-child { margin-bottom: 0; }

  .timeline {
    padding: 20px 22px 18px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    position: relative;
    align-self: start;
  }
  .timeline-lbl {
    position: absolute;
    top: -10px;
    left: 16px;
    background: var(--color-paper);
    padding: 0 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }
  .timeline-list {
    display: flex;
    flex-direction: column;
  }
  .t-row {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 9px 0;
    border-bottom: 1px dashed var(--color-ink-3);
  }
  .t-row:last-child { border-bottom: none; }
  .t-year {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-cyan);
    font-weight: 600;
  }
  .t-line {
    height: 1px;
    background: var(--color-ink-3);
    position: relative;
  }
  .t-line::before {
    content: "";
    position: absolute;
    left: 0;
    top: -3px;
    width: 1px;
    height: 7px;
    background: var(--color-ink);
  }
  .t-event {
    font-size: var(--font-size-sm);
    color: var(--color-ink-2);
    text-align: right;
  }
  @media (max-width: 520px) {
    .t-row { grid-template-columns: 54px 1fr; }
    .t-line { display: none; }
    .t-event { text-align: left; }
  }

  /* Interests — labeled drawing details with icons */
  .interests-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 720px) { .interests-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 420px) { .interests-grid { grid-template-columns: 1fr; } }

  .interest {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    display: flex;
    flex-direction: column;
  }
  .interest-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 12px;
    border-bottom: 1px dashed var(--color-ink-3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .interest-code { color: var(--color-cyan); }
  .interest-pip { color: var(--color-ink-2); }

  .interest-body {
    padding: 20px 18px 22px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
    flex: 1;
  }
  .interest-icon {
    width: 52px;
    height: 52px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    display: grid;
    place-items: center;
    color: var(--color-cyan);
  }
  .interest-icon svg { width: 26px; height: 26px; }
  .interest-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    line-height: 1.15;
  }

  /* Education — credential block */
  .edu {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    position: relative;
  }
  .edu::before,
  .edu::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
  }
  .edu::before { top: -8px; left: -8px; }
  .edu::after { bottom: -8px; right: -8px; }

  .edu-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 10px 18px;
    background: var(--color-chrome-bg);
    color: var(--color-chrome-fg);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .edu-code { color: var(--color-chrome-accent); }

  .edu-body {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 24px 26px 26px;
  }
  @media (max-width: 720px) {
    .edu-body { grid-template-columns: auto 1fr; gap: 16px; }
    .edu-stamp { grid-column: 1 / -1; justify-self: flex-start; }
  }

  .edu-mark {
    width: 56px;
    height: 56px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    display: grid;
    place-items: center;
    color: var(--color-ink);
    flex-shrink: 0;
  }
  .edu-mark svg { width: 30px; height: 30px; }

  .edu-content h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0 0 6px;
    line-height: 1.1;
  }
  .edu-school {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin: 0 0 4px;
  }
  .edu-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-ink-2);
    margin: 0;
  }
</style>
