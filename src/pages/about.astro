---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Philosophy and background of Afroze Amjad, Senior Software Architect focused on GenAI, cloud architecture, and engineering leadership.";

const principles = [
  {
    title: "Simplicity over cleverness",
    description: "The best code is the code you don't have to think about. Reduce cognitive load, make intent obvious."
  },
  {
    title: "Outcomes over technology",
    description: "Technology serves business goals. Choose tools that solve problems, not tools that are interesting."
  },
  {
    title: "Constraints breed creativity",
    description: "Embrace limitations. They focus thinking and lead to elegant solutions."
  },
  {
    title: "Build for change",
    description: "Requirements evolve. Architecture should make change cheap, not prevent it."
  }
];

const timeline = [
  { year: "2014", event: "Graduated from NUST with Electrical Engineering degree" },
  { year: "2014", event: "Joined CureMD in healthcare technology" },
  { year: "2018", event: "Transitioned from analyst to engineering roles" },
  { year: "2020", event: "Led engineering teams and automation initiatives" },
  { year: "2021", event: "First architecture role, API modernization" },
  { year: "2022", event: "Joined Confiz, expanded to enterprise clients" },
  { year: "2024", event: "AI-first projects for Fortune 500 companies" },
  { year: "2025", event: "Senior Architect, Engineering Council lead" },
];

const interests = [
  { label: "AI/ML Systems", icon: "brain" },
  { label: "Distributed Systems", icon: "network" },
  { label: "Developer Experience", icon: "code" },
  { label: "Technical Writing", icon: "pen" },
];
---

<BaseLayout title="About" description={description}>
  <section class="intro">
    <h1>About</h1>
    <p class="lead">
      I build systems that are simple to understand, easy to maintain, and resilient under pressure.
    </p>
  </section>

  <section class="principles">
    <div class="section-header">
      <h2>How I Think</h2>
      <p>Guiding principles for architecture decisions</p>
    </div>
    <div class="principles-grid">
      {principles.map((p, i) => (
        <div class="principle-card">
          <span class="principle-number">{String(i + 1).padStart(2, '0')}</span>
          <h3>{p.title}</h3>
          <p>{p.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="story">
    <div class="section-header">
      <h2>The Path Here</h2>
      <p>From electrical engineering to software architecture</p>
    </div>
    <div class="story-content">
      <div class="story-text">
        <p>
          My journey started in Electrical Engineering at NUST, where I learned to think in systems
          and decompose complex problems. I didn't plan to become a software architect, but each role
          naturally led to the next.
        </p>
        <p>
          A decade in healthcare technology taught me what reliability really means. When your system
          serves thousands of healthcare providers, you learn the cost of downtime and the value of
          boring, predictable architecture.
        </p>
        <p>
          Today, I apply those lessons to AI systems, enterprise platforms, and cloud migrations.
          The technology changes; the principles don't.
        </p>
      </div>
      <div class="timeline">
        {timeline.map((item, i) => (
          <div class="timeline-item">
            <span class="timeline-year">{item.year}</span>
            <span class="timeline-dot"></span>
            <span class="timeline-event">{item.event}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="interests">
    <div class="section-header">
      <h2>Current Interests</h2>
      <p>What I'm exploring and thinking about</p>
    </div>
    <div class="interests-grid">
      {interests.map((item) => (
        <div class="interest-card">
          <div class="interest-icon">
            {item.icon === "brain" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2a9 9 0 0 0-9 9c0 3.6 2.4 6.5 5.5 7.5.3.1.5.4.5.7v2.8h6v-2.8c0-.3.2-.6.5-.7 3.1-1 5.5-3.9 5.5-7.5a9 9 0 0 0-9-9z"/>
                <path d="M12 2v4M8 6l2 2M16 6l-2 2"/>
              </svg>
            )}
            {item.icon === "network" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/>
                <line x1="12" y1="8" x2="5" y2="16"/><line x1="12" y1="8" x2="19" y2="16"/>
              </svg>
            )}
            {item.icon === "code" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              </svg>
            )}
            {item.icon === "pen" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
                <path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>
              </svg>
            )}
          </div>
          <span>{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="education">
    <div class="section-header">
      <h2>Education</h2>
    </div>
    <div class="edu-card">
      <div class="edu-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c0 1.5 2.5 3 6 3s6-1.5 6-3v-5"/>
        </svg>
      </div>
      <div class="edu-content">
        <h3>Bachelor of Electrical Engineering</h3>
        <p class="edu-school">National University of Sciences and Technology (NUST)</p>
        <p class="edu-meta">Islamabad, Pakistan | Class of 2014</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-top: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .intro h1 {
    margin-bottom: var(--space-sm);
  }

  .lead {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 70ch;
    margin: 0;
  }

  /* Section Header */
  .section-header {
    margin-bottom: var(--space-lg);
  }

  .section-header h2 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-xs);
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin: 0;
  }

  /* Principles */
  .principles {
    margin-bottom: var(--space-2xl);
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 480px) {
    .principles-grid {
      grid-template-columns: 1fr;
    }
  }

  .principle-card {
    padding: var(--space-lg);
    border: var(--border-width) solid var(--color-border);
    border-radius: 8px;
    position: relative;
  }

  .principle-number {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent-light);
    line-height: 1;
  }

  .principle-card h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
  }

  .principle-card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Story */
  .story {
    margin-bottom: var(--space-2xl);
  }

  .story-content {
    display: grid;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .story-content {
      grid-template-columns: 1fr 1fr;
    }
  }

  .story-text p {
    font-size: var(--font-size-sm);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .story-text p:last-child {
    margin-bottom: 0;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 50px 12px 1fr;
    gap: var(--space-sm);
    align-items: center;
    font-size: var(--font-size-sm);
  }

  .timeline-year {
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    text-align: right;
  }

  .timeline-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    justify-self: center;
  }

  .timeline-event {
    color: var(--color-text-muted);
  }

  /* Interests */
  .interests {
    margin-bottom: var(--space-2xl);
  }

  .interests-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .interests-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .interest-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-accent-light);
    border-radius: 8px;
    text-align: center;
  }

  .interest-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .interest-icon svg {
    width: 24px;
    height: 24px;
  }

  .interest-card span {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  /* Education */
  .education {
    margin-bottom: var(--space-xl);
  }

  .edu-card {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border: var(--border-width) solid var(--color-border);
    border-radius: 8px;
  }

  .edu-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-light);
    border-radius: 8px;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .edu-icon svg {
    width: 24px;
    height: 24px;
  }

  .edu-content h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-xs);
  }

  .edu-school {
    font-weight: var(--font-weight-medium);
    margin-bottom: var(--space-xs);
  }

  .edu-meta {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
