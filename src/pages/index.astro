---
import BaseLayout from "../layouts/BaseLayout.astro";

const description =
  "Solution Architect specializing in GenAI solutions, cloud architecture, and engineering leadership. 10+ years building scalable platforms for enterprise clients.";

const stats = [
  { value: "10+", label: "Yrs. Exp." },
  { value: "150+", label: "Eng. Led" },
  { value: "50+", label: "Clients" },
];

const impactItems = [
  { id: "M-01", metric: "40%", description: "Development time reduced via microservices framework" },
  { id: "M-02", metric: "15%", description: "Sales conversions increased with AI retail copilot" },
  { id: "M-03", metric: "100h", description: "Monthly savings through DevOps automation" },
  { id: "M-04", metric: "300+", description: "Developers impacted by code quality initiatives" },
];

const focusAreas = [
  {
    code: "F-01 · GEN-AI",
    title: "Generative AI",
    description:
      "AI agents and copilots that deliver measurable business value. Evaluation, cost, and operator trust specified up-front.",
  },
  {
    code: "F-02 · CLOUD",
    title: "Cloud Architecture",
    description:
      "Scalable, cost-aware systems on Azure and AWS. Boring where boring is safer; bold where it pays.",
  },
  {
    code: "F-03 · LEAD",
    title: "Engineering Leadership",
    description:
      "Growing teams and raising technical standards across organizations. Shipping culture over slide culture.",
  },
  {
    code: "F-04 · PLATFORM",
    title: "Platform Modernization",
    description:
      "Migrating legacy estates to cloud-native without breaking the business that depends on them.",
  },
];
---

<BaseLayout title="Home" description={description}>
  <section class="hero">
    <div class="hero-copy">
      <div class="kicker">◊ Sheet 1 of 4 · Portfolio · Field notes</div>
      <h1>
        Building <span class="underline">systems</span> that
        <span class="underline">scale</span>.
      </h1>
      <p class="sub">
        I'm a solution architect who turns complex problems into elegant,
        shippable solutions. From AI copilots to enterprise platforms, I focus
        on outcomes that matter — not architecture theater.
      </p>
      <div class="balloons">
        <span class="balloon"><span class="circle">1</span><span class="txt">GenAI</span></span>
        <span class="balloon"><span class="circle">2</span><span class="txt">Cloud</span></span>
        <span class="balloon"><span class="circle">3</span><span class="txt">Leadership</span></span>
        <span class="balloon"><span class="circle">4</span><span class="txt">Platform</span></span>
      </div>
    </div>
    <aside class="dims">
      {stats.map((s) => (
        <div class="dim-row">
          <span class="val">{s.value}</span>
          <span class="line"></span>
          <span class="lbl">{s.label}</span>
        </div>
      ))}
    </aside>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 01</span>
      <h2>Impact Schedule</h2>
      <span class="rule"></span>
      <span class="scale">Recent engagements · N.T.S.</span>
    </header>
    <table class="schedule">
      <thead>
        <tr>
          <th class="hide-sm">ID</th>
          <th>Metric</th>
          <th class="num-col">Qty</th>
          <th>Specification</th>
        </tr>
      </thead>
      <tbody>
        {impactItems.map((m) => (
          <tr>
            <td class="id hide-sm">{m.id}</td>
            <td>{m.description}</td>
            <td class="num">{m.metric}</td>
            <td class="note">Verified post-engagement</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 02</span>
      <h2>Plan View — Focus Areas</h2>
      <span class="rule"></span>
      <span class="scale">Scale 1:50</span>
    </header>
    <div class="plan">
      {focusAreas.map((f) => (
        <article class="block">
          <div class="code">
            <span>{f.code}</span>
            <span>◊</span>
          </div>
          <h3>{f.title}</h3>
          <p>{f.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 03</span>
      <h2>Key Contacts</h2>
      <span class="rule"></span>
      <span class="scale">Ref. correspondence</span>
    </header>
    <div class="connect">
      <a href="https://linkedin.com/in/afroze-amjad" target="_blank" rel="noopener noreferrer" class="pin">
        <span class="mark">in</span>
        <div>
          <div class="ch">LinkedIn</div>
          <div class="nm">afroze-amjad</div>
        </div>
      </a>
      <a href="https://github.com/afroze9" target="_blank" rel="noopener noreferrer" class="pin">
        <span class="mark">gh</span>
        <div>
          <div class="ch">GitHub</div>
          <div class="nm">afroze9</div>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero — drawing with a dimension-panel sidebar */
  .hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 36px;
    padding: 12px 0 32px;
    border-bottom: 1px dashed var(--color-ink-3);
    margin-bottom: 8px;
    position: relative;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin-bottom: 14px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(40px, 5vw, 68px);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 22px;
    color: var(--color-ink);
  }
  .hero h1 .underline {
    text-decoration: underline;
    text-decoration-color: var(--color-cyan);
    text-decoration-thickness: 2px;
    text-underline-offset: 6px;
  }

  .hero .sub {
    font-size: var(--font-size-lg);
    max-width: 56ch;
    color: var(--color-ink-2);
    line-height: 1.6;
  }

  .balloons {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 0;
    align-items: center;
  }

  /* Dimensions panel */
  .dims {
    padding: 18px 20px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper-2);
    position: relative;
    align-self: start;
  }
  .dims::before {
    content: "DETAIL A · SCALE 1:1";
    position: absolute;
    top: -10px;
    left: 14px;
    background: var(--color-paper);
    padding: 0 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-ink-2);
  }
  .dim-row {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px dashed var(--color-ink-3);
  }
  .dim-row:last-child { border-bottom: none; }
  .dim-row .val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 28px;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .dim-row .line {
    height: 1px;
    background: var(--color-ink);
    position: relative;
  }
  .dim-row .line::before,
  .dim-row .line::after {
    content: "";
    position: absolute;
    top: -4px;
    width: 1px;
    height: 9px;
    background: var(--color-ink);
  }
  .dim-row .line::before { left: 0; }
  .dim-row .line::after { right: 0; }
  .dim-row .lbl {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }

  /* Impact schedule table */
  .schedule {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
  }
  .schedule th,
  .schedule td {
    padding: 14px 16px;
    border: 1px solid var(--color-ink);
    text-align: left;
    vertical-align: top;
  }
  .schedule th {
    background: var(--color-ink);
    color: var(--color-desk);
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .schedule th.num-col { text-align: right; width: 120px; }
  .schedule td.num {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    color: var(--color-cyan);
    text-align: right;
    white-space: nowrap;
  }
  .schedule td.id {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-2);
    width: 74px;
    white-space: nowrap;
  }
  .schedule td.note {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-3);
    width: 32%;
  }

  /* Plan view — corner-marked blocks */
  .plan {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .block {
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    padding: 20px 22px 22px;
    position: relative;
  }
  .block::before,
  .block::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
  }
  .block::before { top: -7px; left: -7px; }
  .block::after { bottom: -7px; right: -7px; }
  .block .code {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-cyan);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
  }
  .block h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 8px;
    color: var(--color-ink);
  }
  .block p {
    font-size: var(--font-size-sm);
    color: var(--color-ink-2);
    line-height: 1.55;
    margin: 0;
  }

  /* Connect — pinned marks */
  .connect {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .pin {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper-2);
    text-decoration: none;
    color: var(--color-ink);
    transition: background 0.12s ease, border-color 0.12s ease;
  }
  .pin:hover {
    border-color: var(--color-cyan);
    border-bottom-color: var(--color-cyan);
    background: var(--color-paper);
  }
  .pin .mark {
    width: 42px;
    height: 42px;
    border: 1.5px solid var(--color-ink);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 12px;
    background: var(--color-paper);
    flex-shrink: 0;
  }
  .pin:hover .mark {
    border-color: var(--color-cyan);
    color: var(--color-cyan);
  }
  .pin .ch {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }
  .pin .nm {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  @media (max-width: 820px) {
    .hero { grid-template-columns: 1fr; gap: 28px; }
    .plan,
    .connect { grid-template-columns: 1fr; }
    .schedule th.hide-sm,
    .schedule td.hide-sm { display: none; }
    .schedule td.note { display: none; }
  }
</style>
