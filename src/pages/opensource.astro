---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Open source projects and contributions by Afroze Amjad on GitHub.";

const githubProjects = [
  {
    name: "terrastudio",
    description: "Visual infrastructure diagram builder that generates and executes Terraform. Drag-and-drop Azure resources onto a canvas, configure them visually, and export production-ready Terraform code.",
    language: "TypeScript",
    url: "https://github.com/afroze9/terrastudio",
    topics: ["terraform", "infrastructure-as-code", "svelte", "tauri"],
  },
  {
    name: "graph-cli",
    description: "Command-line interface for Microsoft Graph. Access Outlook email, Teams chats, calendar, To Do tasks, presence, and SharePoint/OneDrive files from your terminal.",
    language: "TypeScript",
    url: "https://github.com/afroze9/graph-cli",
    topics: ["microsoft-graph", "cli", "teams", "outlook"],
  },
  {
    name: "atlas-cli",
    description: "Terminal-native interface for Jira and Confluence. Manage issues, sprints, boards, and pages without leaving the shell.",
    language: "TypeScript",
    url: "https://github.com/afroze9/atlas-cli",
    topics: ["jira", "confluence", "atlassian", "cli"],
  },
  {
    name: "asana-cli",
    description: "Command-line access to Asana projects, tasks, and workspaces. Built for keyboard-driven workflow management.",
    language: "TypeScript",
    url: "https://github.com/afroze9/asana-cli",
    topics: ["asana", "productivity", "cli", "workflow"],
  },
  {
    name: "nexus",
    description: "Multi-tenant application framework with .NET microservices architecture. Features service discovery, API gateway, and distributed configuration.",
    language: "C#",
    url: "https://github.com/nexus-framework/nexus",
    topics: ["microservices", "multi-tenant", ".net", "docker"],
  },
  {
    name: "solid-auth0",
    description: "Auth0 authentication integration for SolidJS applications. Provides hooks and components for seamless OAuth flows.",
    language: "TypeScript",
    url: "https://github.com/afroze9/solid-auth0",
    topics: ["solidjs", "auth0", "authentication", "oauth"],
  },
  {
    name: "project-management",
    description: "Full-stack project management system built with Clean Architecture and DDD patterns. Demonstrates CQRS, MediatR, and modern .NET practices.",
    language: "C#",
    url: "https://github.com/afroze-project-management",
    topics: ["clean-architecture", "ddd", "cqrs", "efcore"],
  },
  {
    name: "sk-assistant",
    description: "AI assistant built with Semantic Kernel. Demonstrates LLM integration, prompt engineering, and intelligent agent patterns.",
    language: "C#",
    url: "https://github.com/afroze9/sk-assistant",
    topics: ["semantic-kernel", "ai", "llm", "agents"],
  },
];

const stats = [
  { label: "Repositories", value: "20+" },
  { label: "Primary Language", value: "C#" },
  { label: "Focus Areas", value: ".NET, Cloud" },
];

const pad = (n: number) => n.toString().padStart(2, "0");
---

<BaseLayout title="Open Source" description={description}>
  <section class="intro">
    <div class="kicker">◊ Sheet 4 of 4 · Open source register</div>
    <h1>Open Source</h1>
    <p class="sub">
      Personal projects, experiments, and contributions on GitHub. Building in
      public and sharing what I learn.
    </p>
  </section>

  <section class="profile-wrap">
    <div class="profile">
      <div class="profile-mark">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </div>
      <div class="profile-info">
        <div class="profile-code">GH · REGISTER</div>
        <div class="profile-handle">@afroze9</div>
        <a
          href="https://github.com/afroze9"
          target="_blank"
          rel="noopener noreferrer"
          class="profile-link"
        >
          View Profile →
        </a>
      </div>
      <aside class="profile-dims">
        <div class="profile-dims-lbl">Detail B · Scale 1:1</div>
        {stats.map((stat) => (
          <div class="dim-row">
            <span class="val">{stat.value}</span>
            <span class="line"></span>
            <span class="lbl">{stat.label}</span>
          </div>
        ))}
      </aside>
    </div>
  </section>

  <section>
    <header class="section-head">
      <span class="tag">§ 01</span>
      <h2>Featured Repositories</h2>
      <span class="rule"></span>
      <span class="scale">Scale 1:50</span>
    </header>
    <div class="repo-grid">
      {githubProjects.map((repo, i) => (
        <a href={repo.url} class="repo-card" target="_blank" rel="noopener noreferrer">
          <div class="repo-head">
            <span class="repo-code">REPO-{pad(i + 1)}</span>
            <span class="repo-lang" data-lang={repo.language}>
              <span class="lang-dot"></span>{repo.language}
            </span>
            <svg class="repo-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17l9.2-9.2M17 17V7H7"/>
            </svg>
          </div>
          <div class="repo-body">
            <div class="repo-name-row">
              <svg class="repo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
              </svg>
              <span class="repo-name">{repo.name}</span>
            </div>
            <p class="repo-desc">{repo.description}</p>
          </div>
          <footer class="repo-foot">
            <span class="topics-lbl">§ Topics</span>
            <div class="repo-topics">
              {repo.topics.map((topic) => (
                <span class="topic-tag">{topic}</span>
              ))}
            </div>
          </footer>
        </a>
      ))}
    </div>
  </section>

  <section class="cta-block">
    <div class="cta-head">
      <span class="cta-tag">§ 02 · Collaborate</span>
      <span class="cta-rule"></span>
    </div>
    <div class="cta-body">
      <div>
        <h2>Want to collaborate?</h2>
        <p>I'm always open to interesting projects and contributions.</p>
      </div>
      <a href="https://github.com/afroze9" target="_blank" rel="noopener noreferrer" class="cta-link">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        Follow on GitHub
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Intro */
  .intro { padding-top: var(--space-md); margin-bottom: var(--space-xl); }
  .intro .kicker {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin-bottom: 12px;
  }
  .intro h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: var(--color-ink);
  }
  .intro .sub {
    font-size: var(--font-size-lg);
    color: var(--color-ink-2);
    max-width: 70ch;
    margin: 0;
  }

  /* Profile as a spec block */
  .profile-wrap { margin-bottom: var(--space-2xl); }
  .profile {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 28px;
    align-items: center;
    padding: 24px 28px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    position: relative;
  }
  .profile::before {
    content: "PROFILE · DETAIL A";
    position: absolute;
    top: -10px;
    left: 16px;
    background: var(--color-paper);
    padding: 0 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-ink-2);
  }

  .profile-mark {
    width: 56px;
    height: 56px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    display: grid;
    place-items: center;
    color: var(--color-ink);
  }
  .profile-mark svg { width: 34px; height: 34px; }

  .profile-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .profile-code {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-cyan);
  }
  .profile-handle {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 26px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink);
    line-height: 1;
  }
  .profile-link {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cyan);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    align-self: flex-start;
  }
  .profile-link:hover { border-bottom-color: var(--color-cyan); }

  .profile-dims {
    padding: 14px 18px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
    min-width: 280px;
    position: relative;
  }
  .profile-dims-lbl {
    position: absolute;
    top: -9px;
    left: 12px;
    background: var(--color-paper-2);
    padding: 0 6px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }
  .profile-dims .dim-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px dashed var(--color-ink-3);
  }
  .profile-dims .dim-row:last-child { border-bottom: none; }
  .profile-dims .val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    color: var(--color-ink);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .profile-dims .line {
    height: 1px;
    background: var(--color-ink);
    position: relative;
  }
  .profile-dims .line::before,
  .profile-dims .line::after {
    content: "";
    position: absolute;
    top: -3px;
    width: 1px;
    height: 7px;
    background: var(--color-ink);
  }
  .profile-dims .line::before { left: 0; }
  .profile-dims .line::after { right: 0; }
  .profile-dims .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    white-space: nowrap;
  }

  @media (max-width: 820px) {
    .profile { grid-template-columns: 1fr; gap: 18px; text-align: left; }
    .profile-dims { min-width: 0; }
  }

  /* Repo grid */
  .repo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (max-width: 720px) {
    .repo-grid { grid-template-columns: 1fr; }
  }

  .repo-card {
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    color: var(--color-ink);
    text-decoration: none;
    transition: border-color 0.12s ease, background 0.12s ease;
    position: relative;
  }
  .repo-card:hover {
    border-color: var(--color-cyan);
    background: var(--color-paper-2);
  }

  .repo-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 16px;
    background: var(--color-chrome-bg);
    color: var(--color-chrome-fg);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .repo-code { color: var(--color-chrome-accent); flex: 0 0 auto; }
  .repo-lang {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }
  .lang-dot {
    width: 9px;
    height: 9px;
    background: var(--lang-color, var(--color-chrome-fg));
    border: 1px solid var(--color-chrome-fg);
  }
  .repo-lang[data-lang="C#"] { --lang-color: #178600; }
  .repo-lang[data-lang="TypeScript"] { --lang-color: #3178c6; }
  .repo-lang[data-lang="JavaScript"] { --lang-color: #f1e05a; }
  .repo-lang[data-lang="Python"] { --lang-color: #3572A5; }
  .repo-lang[data-lang="Astro"] { --lang-color: #ff5a03; }
  .repo-out {
    width: 14px;
    height: 14px;
    opacity: 0.5;
    transition: opacity 0.12s ease, color 0.12s ease;
  }
  .repo-card:hover .repo-out { opacity: 1; color: var(--color-cyan); }

  .repo-body {
    padding: 20px 22px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .repo-name-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--color-ink-3);
  }
  .repo-icon {
    width: 16px;
    height: 16px;
    color: var(--color-ink-2);
    flex-shrink: 0;
  }
  .repo-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink);
    line-height: 1;
  }
  .repo-card:hover .repo-name { color: var(--color-cyan); }
  .repo-desc {
    font-size: var(--font-size-sm);
    line-height: 1.55;
    color: var(--color-ink-2);
    margin: 0;
  }

  .repo-foot {
    padding: 14px 22px 16px;
    border-top: 1px solid var(--color-ink);
    background: var(--color-paper-2);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .topics-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-cyan);
  }
  .repo-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .topic-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    padding: 3px 7px;
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
  }
  .repo-card:hover .topic-tag { border-color: var(--color-ink-2); }

  /* CTA (same pattern as projects page) */
  .cta-block {
    margin-top: var(--space-2xl);
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper-2);
    position: relative;
  }
  .cta-block::before {
    content: "";
    position: absolute;
    inset: 6px;
    border: 1px solid var(--color-ink-3);
    pointer-events: none;
  }
  .cta-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 20px;
    border-bottom: 1px dashed var(--color-ink-3);
    position: relative;
    z-index: 1;
  }
  .cta-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-cyan);
    text-transform: uppercase;
  }
  .cta-rule { flex: 1; height: 1px; background: var(--color-ink-3); }
  .cta-body {
    padding: 22px 26px 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px) {
    .cta-body { flex-direction: row; align-items: center; gap: 24px; }
  }
  .cta-body h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 26px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0 0 4px;
    line-height: 1;
  }
  .cta-body p {
    color: var(--color-ink-2);
    font-size: var(--font-size-sm);
    margin: 0;
  }
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
    padding: 10px 16px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    text-decoration: none;
    transition: background 0.12s ease, color 0.12s ease;
    flex-shrink: 0;
  }
  .cta-link svg { width: 16px; height: 16px; }
  .cta-link:hover { background: var(--color-ink); color: var(--color-paper); }
</style>
